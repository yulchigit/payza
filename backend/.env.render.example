# Render backend production environment template
# DO NOT COMMIT real values - use Render dashboard for secrets

NODE_ENV=production
PORT=5000

# Database - Get from Render PostgreSQL service internal connection string
DATABASE_URL=postgresql://user:password@postgres:5432/payza_db

# JWT - Generate with: node scripts/generate-jwt-secret.js
JWT_SECRET=your-64-character-random-secret-key-here-change-this-value
JWT_ISSUER=payza-api
JWT_AUDIENCE=payza-clients
JWT_EXPIRES_IN=7d

# CORS - Add your Vercel domain and mobile origins
# Format: https://yourdomain.com,capacitor://localhost,ionic://localhost
CORS_ORIGINS=https://payza-web.vercel.app,https://yourdomain.com,capacitor://localhost,ionic://localhost
CORS_ALLOW_MOBILE_LOCALHOST_ORIGIN=true

# Backend domain for CSP header
BACKEND_DOMAIN=https://payza-backend.onrender.com

# Security
BCRYPT_ROUNDS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

# Rate limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300

# Demo swap settings
DEMO_SWAP_FEE_BPS=50
DEMO_SWAP_SPREAD_BPS=20
