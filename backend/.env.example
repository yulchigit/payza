NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payza

JWT_SECRET=change-me-to-64-char-random-secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=payza-api
JWT_AUDIENCE=payza-clients

BCRYPT_ROUNDS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
DEMO_SWAP_FEE_BPS=50
DEMO_SWAP_SPREAD_BPS=20

# Comma-separated allowed origins.
# Local development:
CORS_ORIGINS=http://localhost:4029,http://127.0.0.1:4029,capacitor://localhost,http://localhost,http://127.0.0.1
CORS_ALLOW_MOBILE_LOCALHOST_ORIGIN=true

# Production on Render (update with your Vercel frontend domain):
# CORS_ORIGINS=https://payza.vercel.app,https://www.payza.vercel.app
# CORS_ALLOW_MOBILE_LOCALHOST_ORIGIN=false

